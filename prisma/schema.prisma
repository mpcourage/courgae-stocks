generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model StockSnapshot {
  symbol    String   @id
  name      String
  sector    String
  price     Float
  prevClose Float
  change    Float
  changePct Float
  dayOpen   Float
  dayHigh   Float
  dayLow    Float
  volume    Int
  updatedAt DateTime @updatedAt
}

model Universe {
  symbol    String   @id
  name      String
  sector    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HistoryBar {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Int
  createdAt DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol, date])
}
